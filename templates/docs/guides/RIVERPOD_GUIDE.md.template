## Common Patterns

### Pattern 1: Form with Validation

```dart
@riverpod
class {{PRIMARY_ENTITY}}FormNotifier extends _${{PRIMARY_ENTITY}}FormNotifier {
  final {{PRIMARY_ENTITY}}FormValidator _validator = const {{PRIMARY_ENTITY}}FormValidator();

  @override
  {{PRIMARY_ENTITY}}FormState build() {
    return {{PRIMARY_ENTITY}}FormState.initial();
  }

  void setNominal(double value) {
    final errors = Map<String, String>.from(state.validationErrors);
    final error = _validator.validateNominal(value);

    if (error != null) {
      errors['nominal'] = error;
    } else {
      errors.remove('nominal');
    }

    state = state.copyWith(
      nominal: value,
      validationErrors: errors,
    );
  }

  Future<void> submit() async {
    // Validate all fields
    final errors = _validator.validateAll(state);
    if (errors.isNotEmpty) {
      state = state.copyWith(validationErrors: errors);
      return;
    }

    // Submit
    state = const {{PRIMARY_ENTITY}}FormState.loading();
    final controller = _getSubmissionController();
    final result = await controller.submit(formState: state);

    result.fold(
      (failure) => state = {{PRIMARY_ENTITY}}FormState.error(failure.message),
      (success) => state = {{PRIMARY_ENTITY}}FormState.success(success),
    );
  }
}
```

### Pattern 2: Infinite Scroll (Pagination)

```dart
@riverpod
class {{PRIMARY_ENTITY}}ListPaginatedNotifier extends _${{PRIMARY_ENTITY}}ListPaginatedNotifier {
  static const _pageSize = 20;

  @override
  Future<PaginatedResult<{{PRIMARY_ENTITY}}Entity>> build() async {
    return await _loadPage(offset: 0);
  }

  Future<PaginatedResult<{{PRIMARY_ENTITY}}Entity>> _loadPage({required int offset}) async {
    final useCase = ref.read(get{{PRIMARY_ENTITY}}PaginatedUseCaseProvider);
    final result = await useCase.execute(
      PaginatedParams(limit: _pageSize, offset: offset),
    );

    return result.fold(
      (failure) => throw Exception(failure.message),
      (data) => data,
    );
  }

  Future<void> loadNextPage() async {
    final current = state.valueOrNull;
    if (current == null || current.hasMore == false) return;

    state = const AsyncValue.loading();

    final next = await _loadPage(offset: current.items.length);

    state = AsyncValue.data(PaginatedResult(
      items: [...current.items, ...next.items],
      hasMore: next.hasMore,
    ));
  }
}
```

