### Pattern 4: Search with Debounce

```dart
@riverpod
class {{PRIMARY_ENTITY}}SearchNotifier extends _${{PRIMARY_ENTITY}}SearchNotifier {
  Timer? _debounceTimer;

  @override
  {{PRIMARY_ENTITY}}SearchState build() {
    ref.onDispose(() {
      _debounceTimer?.cancel();
    });

    return {{PRIMARY_ENTITY}}SearchState.initial();
  }

  void onQueryChanged(String query) {
    state = state.copyWith(query: query);

    _debounceTimer?.cancel();
    _debounceTimer = Timer(const Duration(milliseconds: 500), () {
      _performSearch(query);
    });
  }

  Future<void> _performSearch(String query) async {
    if (query.isEmpty) {
      state = {{PRIMARY_ENTITY}}SearchState.initial();
      return;
    }

    state = state.copyWith(isSearching: true);

    final searchRepo = ref.read({{PRIMARY_ENTITY}}SearchRepositoryProvider);
    final result = await searchRepo.search{{PRIMARY_ENTITY}}Plural(query);

    result.fold(
      (failure) => state = state.copyWith(
        isSearching: false,
        errorMessage: failure.message,
      ),
      (results) => state = state.copyWith(
        isSearching: false,
        results: results,
      ),
    );
  }

  void clear() {
    state = {{PRIMARY_ENTITY}}SearchState.initial();
    _debounceTimer?.cancel();
  }
}
```

