## Advanced Features

### FromJson/ToJson with JsonSerializable

```dart
import 'package:freezed_annotation/freezed_annotation.dart';
import 'package:json_serializable/json_serializable.dart';

part '{{PRIMARY_ENTITY_LOWER}}_model.freezed.dart';
part '{{PRIMARY_ENTITY_LOWER}}_model.g.dart';

@freezed
abstract class {{PRIMARY_ENTITY}}Model with _${{PRIMARY_ENTITY}}Model {
  const {{PRIMARY_ENTITY}}Model._();

  const factory {{PRIMARY_ENTITY}}Model({
    int? id,
    required double amount,
    @JsonKey(name: 'type') required String typeStr,
    @JsonKey(name: 'date_time') required String dateTimeStr,
    required int {{SECONDARY_ENTITY_LOWER}}Id,
    String? note,
    @JsonKey(name: 'created_at') required String createdAtStr,
  }) = _{{PRIMARY_ENTITY}}Model;

  factory {{PRIMARY_ENTITY}}Model.fromJson(Map<String, dynamic> json) =>
      _${{PRIMARY_ENTITY}}ModelFromJson(json);

  Map<String, dynamic> toJson() => _${{PRIMARY_ENTITY}}ModelToJson(this);

  // Convert to entity
  {{PRIMARY_ENTITY}}Entity toEntity() {
    return {{PRIMARY_ENTITY}}Entity(
      id: id,
      amount: amount,
      type: typeStr == 'income' ? {{PRIMARY_ENTITY}}Type.income : {{PRIMARY_ENTITY}}Type.{{SECONDARY_ENTITY}},
      dateTime: DateTime.parse(dateTimeStr),
      {{SECONDARY_ENTITY_LOWER}}Id: {{SECONDARY_ENTITY_LOWER}}Id,
      note: note,
      createdAt: DateTime.parse(createdAtStr),
    );
  }

  // Convert from entity
  factory {{PRIMARY_ENTITY}}Model.fromEntity({{PRIMARY_ENTITY}}Entity entity) {
    return {{PRIMARY_ENTITY}}Model(
      id: entity.id,
      amount: entity.amount,
      typeStr: entity.type.name,
      dateTimeStr: entity.dateTime.toIso8601String(),
      {{SECONDARY_ENTITY_LOWER}}Id: entity.{{SECONDARY_ENTITY_LOWER}}Id,
      note: entity.note,
      createdAtStr: entity.createdAt.toIso8601String(),
    );
  }
}
```

### Union Types with Generics

```dart
@freezed
abstract class Result<T> with _$Result<T> {
  const factory Result.success(T data) = ResultSuccess<T>;
  const factory Result.failure(Failure failure) = ResultFailure<T>;
}

// Usage
Future<Result<{{PRIMARY_ENTITY}}Entity>> add{{PRIMARY_ENTITY}}({{PRIMARY_ENTITY}}Entity entity) async {
  try {
    final id = await _database.insert(entity);
    final result = entity.copyWith(id: id);
    return Result.success(result);
  } catch (e) {
    return Result.failure(DatabaseFailure(e.toString()));
  }
}

// Handle
final result = await add{{PRIMARY_ENTITY}}({{PRIMARY_ENTITY_LOWER}});
result.when(
  success: (data) => print('Success: $data'),
  failure: (failure) => print('Failure: ${failure.message}'),
);
