## Immutable Classes

### What Are Immutable Classes?

Immutable classes cannot be modified after creation. Freezed makes this easy by generating `copyWith` methods.

### Example: Immutable Entity

```dart
@freezed
abstract class {{SECONDARY_ENTITY}}Entity with _${{SECONDARY_ENTITY}}Entity {
  const {{SECONDARY_ENTITY}}Entity._();

  const factory {{SECONDARY_ENTITY}}Entity({
    int? id,
    required String name,
    required {{PRIMARY_ENTITY}}Type type,
    required String color,
    String? icon,
    @Default(0) int sortOrder,
    @Default(true) bool isActive,
    required DateTime createdAt,
    DateTime? updatedAt,
  }) = _{{SECONDARY_ENTITY}}Entity;

  // Business logic
  bool get isIncome => type == {{PRIMARY_ENTITY}}Type.income;
  bool get is{{SECONDARY_ENTITY}} => type == {{PRIMARY_ENTITY}}Type.{{SECONDARY_ENTITY}};

  String get displayName => isActive ? name : '$name (Non-aktif)';

  // Custom method
  {{SECONDARY_ENTITY}}Entity activate() {
    return copyWith(isActive: true);
  }

  {{SECONDARY_ENTITY}}Entity deactivate() {
    return copyWith(isActive: false);
  }
}

// Usage
final {{SECONDARY_ENTITY_LOWER}} = {{SECONDARY_ENTITY}}Entity(
  name: 'Makanan',
  type: {{PRIMARY_ENTITY}}Type.{{SECONDARY_ENTITY}},
  color: '#FF5722',
  createdAt: DateTime.now(),
);

// Can't modify directly
// {{SECONDARY_ENTITY_LOWER}}.name = 'New Name'; // ❌ Compilation error

// Use copyWith to create new instance
final updated = {{SECONDARY_ENTITY_LOWER}}.copyWith(
  name: 'Makanan & Minuman',
); // ✅ Creates new instance

// Use custom methods
final activated = {{SECONDARY_ENTITY_LOWER}}.activate();
final deactivated = {{SECONDARY_ENTITY_LOWER}}.deactivate();
```

