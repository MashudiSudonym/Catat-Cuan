## Error Handling Patterns

### Result Type (Either Pattern)

```dart
// Use Either from dartz package or custom Result type
import 'package:{{PROJECT_NAME}}/domain/core/result.dart';

// ✅ GOOD - Return Result type
Future<Either<Failure, {{PRIMARY_ENTITY}}Entity>> add{{PRIMARY_ENTITY}}(
  {{PRIMARY_ENTITY}}Entity {{PRIMARY_ENTITY_LOWER}},
) async {
  try {
    final id = await _database.insert({{PRIMARY_ENTITY_LOWER}});
    final result = {{PRIMARY_ENTITY_LOWER}}.copyWith(id: id);
    return Right(result);
  } on DatabaseException catch (e) {
    return Left(DatabaseFailure(e.message));
  }
}

// ❌ BAD - Throw exceptions
Future<{{PRIMARY_ENTITY}}Entity> add{{PRIMARY_ENTITY}}(
  {{PRIMARY_ENTITY}}Entity {{PRIMARY_ENTITY_LOWER}},
) async {
  try {
    final id = await _database.insert({{PRIMARY_ENTITY_LOWER}});
    return {{PRIMARY_ENTITY_LOWER}}.copyWith(id: id);
  } catch (e) {
    throw Exception('Failed to add {{PRIMARY_ENTITY_LOWER}}'); // Don't throw!
  }
}
```

### Failure Types

```dart
/// Base failure class
abstract class Failure {
  final String message;
  const Failure(this.message);

  @override
  String toString() => message;
}

/// Specific failure types
class DatabaseFailure extends Failure {
  const DatabaseFailure(super.message);
}

class ValidationFailure extends Failure {
  const ValidationFailure(super.message);
}

class NetworkFailure extends Failure {
  const NetworkFailure(super.message);
}

class OcrFailure extends Failure {
  const OcrFailure(super.message);
}

class PermissionFailure extends Failure {
  const PermissionFailure(super.message);
}
```

### Handling Errors in UI

```dart
// ✅ GOOD - Handle errors gracefully
final state = ref.watch({{PRIMARY_ENTITY}}ListProvider);

return state.when(
  loading: () => const AppLoadingState(),
  error: (error, stackTrace) {
    final message = ErrorMessageMapper.map(error);
    return AppErrorState(
      error: message,
      onRetry: () => ref.invalidate({{PRIMARY_ENTITY}}ListProvider),
    );
  },
  data: ({{PRIMARY_ENTITY_PLURAL}}) => {{PRIMARY_ENTITY}}List({{PRIMARY_ENTITY_PLURAL}}: {{PRIMARY_ENTITY_PLURAL}}),
);

// ❌ BAD - Let errors crash the app
final state = ref.watch({{PRIMARY_ENTITY}}ListProvider);
return {{PRIMARY_ENTITY}}List({{PRIMARY_ENTITY_PLURAL}}: state.value!); // Crashes if error!
```

### AsyncValue.guard

```dart
// ✅ GOOD - Use AsyncValue.guard for automatic error handling
Future<void> submit() async {
  state = const AsyncValue.loading();
  state = await AsyncValue.guard(() async {
    return await _performSubmission();
  });
}

// ❌ BAD - Manual try-catch
Future<void> submit() async {
  state = const AsyncValue.loading();
  try {
    final result = await _performSubmission();
    state = AsyncValue.data(result);
  } catch (e, st) {
    state = AsyncValue.error(e, st);
  }
}
```

