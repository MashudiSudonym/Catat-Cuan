### Unit Test Structure

```dart
// test/domain/usecases/add_{{PRIMARY_ENTITY_LOWER}}_usecase_test.dart
import 'package:flutter_test/flutter_test.dart';
import 'package:mockito/mockito.dart';
import 'package:{{PROJECT_NAME}}/domain/usecases/add_{{PRIMARY_ENTITY_LOWER}}_usecase.dart';

void main() {
  late Add{{PRIMARY_ENTITY}}UseCase useCase;
  late Mock{{PRIMARY_ENTITY}}WriteRepository mockRepository;

  setUp(() {
    mockRepository = Mock{{PRIMARY_ENTITY}}WriteRepository();
    useCase = Add{{PRIMARY_ENTITY}}UseCase(mockRepository);
  });

  group('Add{{PRIMARY_ENTITY}}UseCase', () {
    test('should return validation failure when amount is zero', () async {
      // Arrange
      final {{PRIMARY_ENTITY_LOWER}} = {{PRIMARY_ENTITY}}Entity(
        amount: 0,
        type: {{PRIMARY_ENTITY}}Type.{{SECONDARY_ENTITY}},
        dateTime: DateTime.now(),
        {{SECONDARY_ENTITY_LOWER}}Id: 1,
        createdAt: DateTime.now(),
      );

      // Act
      final result = await useCase.execute({{PRIMARY_ENTITY_LOWER}});

      // Assert
      expect(result.isLeft(), true);
      expect(result.fold((l) => l, (r) => null), isA<ValidationFailure>());
    });

    test('should add {{PRIMARY_ENTITY_LOWER}} successfully', () async {
      // Arrange
      final {{PRIMARY_ENTITY_LOWER}} = {{PRIMARY_ENTITY}}Entity(
        amount: 100,
        type: {{PRIMARY_ENTITY}}Type.{{SECONDARY_ENTITY}},
        dateTime: DateTime.now(),
        {{SECONDARY_ENTITY_LOWER}}Id: 1,
        createdAt: DateTime.now(),
      );
      final expected = {{PRIMARY_ENTITY_LOWER}}.copyWith(id: 1);

      when(mockRepository.add{{PRIMARY_ENTITY}}({{PRIMARY_ENTITY_LOWER}}))
          .thenAnswer((_) async => Right(expected));

      // Act
      final result = await useCase.execute({{PRIMARY_ENTITY_LOWER}});

      // Assert
      expect(result.isRight(), true);
      result.fold(
        (l) => fail('Should return Right'),
        (r) {
          expect(r.id, 1);
          expect(r.amount, 100);
        },
      );
      verify(mockRepository.add{{PRIMARY_ENTITY}}({{PRIMARY_ENTITY_LOWER}})).called(1);
    });
  });
}
```

