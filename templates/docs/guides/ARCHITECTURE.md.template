      final model = {{PRIMARY_ENTITY}}Model.fromEntity({{PRIMARY_ENTITY_LOWER}});
      await _dataSource.update(table{{PRIMARY_ENTITY}}Plural, model.toMap(),
        where: 'id = ?',
