## Controller Pattern

**Purpose**: Extract business logic from state management (providers) into dedicated controllers.

### Problem: Business Logic in Providers

```dart
// BAD - Business logic mixed with state management
@riverpod
class {{PRIMARY_ENTITY}}FormNotifier extends _${{PRIMARY_ENTITY}}FormNotifier {
  @override
  {{PRIMARY_ENTITY}}FormState build() {
    return {{PRIMARY_ENTITY}}FormState.initial();
  }

  Future<void> submit() async {
    state = const {{PRIMARY_ENTITY}}FormState.loading();

    // Business logic embedded in provider
    final isAdd = state.existing{{PRIMARY_ENTITY}} == null;
    final entity = _mapToEntity(state);

    if (isAdd) {
      // Validation logic
      if (entity.amount <= 0) {
        state = {{PRIMARY_ENTITY}}FormState.error('Invalid amount');
        return;
      }

      // Add logic
      final result = await ref.read(add{{PRIMARY_ENTITY}}UseCaseProvider).execute(entity);
      result.fold(
        (failure) => state = {{PRIMARY_ENTITY}}FormState.error(failure.message),
        (success) {
          state = {{PRIMARY_ENTITY}}FormState.success(success);
          ref.invalidate({{PRIMARY_ENTITY}}ListProvider);
        },
      );
    } else {
      // Update logic
      final result = await ref.read(update{{PRIMARY_ENTITY}}UseCaseProvider).execute(entity);
      // Similar handling...
    }
  }

  // More business logic...
  {{PRIMARY_ENTITY}}Entity _mapToEntity({{PRIMARY_ENTITY}}FormState state) { }
  void _handleSuccess({{PRIMARY_ENTITY}}Entity entity) { }
  void _handleError(Failure failure) { }
}
```

