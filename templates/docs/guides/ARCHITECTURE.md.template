      final id = await _dataSource.insert(table{{PRIMARY_ENTITY}}Plural, model.toMap());
      final result = {{PRIMARY_ENTITY_LOWER}}.copyWith(id: id);
      return Right(result);
    } on DatabaseException catch (e) {
